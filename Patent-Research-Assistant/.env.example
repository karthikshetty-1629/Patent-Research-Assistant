# Copy to .env and fill in values. Never commit the real .env file.

# --- AWS ---
AWS_REGION=us-east-1
S3_BUCKET=patent-research-assistant
S3_RAW_PREFIX=uspto/fulltext

# --- OpenSearch (vector store) ---
OPENSEARCH_ENDPOINT=https://search-your-domain.us-east-1.es.amazonaws.com
OPENSEARCH_INDEX=patents
OPENSEARCH_USE_IAM_AUTH=true
# Only used when OPENSEARCH_USE_IAM_AUTH=false (local/dev clusters):
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin

# --- Embeddings ---
EMBEDDING_MODEL_NAME=AI-Growth-Lab/PatentSBERTa
EMBEDDING_DIMENSIONS=768
EMBEDDING_BATCH_SIZE=32

# --- LLM (generation) ---
# huggingface | sagemaker | bedrock
LLM_PROVIDER=huggingface
LLM_MODEL_NAME=tiiuae/falcon-7b-instruct
SAGEMAKER_ENDPOINT_NAME=
HUGGINGFACEHUB_API_TOKEN=
LLM_MAX_NEW_TOKENS=512
LLM_TEMPERATURE=0.2

# --- Retrieval ---
RETRIEVAL_TOP_K=5

# --- Auth (Cognito) ---
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
